rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: anyone authenticated can read (for leaderboard),
    // but only the user themselves can write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Collections: authenticated users can read all (for trades/leaderboard),
    // but only the owner can write their own collection entries
    match /collections/{entryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Stickers: read-only for all authenticated users
    match /stickers/{stickerId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin only via seeding scripts
    }

    // Trades: authenticated users can read all, create their own
    match /trades/{tradeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.offeredBy == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.offeredBy == request.auth.uid
          || resource.data.neededBy == request.auth.uid);
      allow delete: if request.auth != null
        && resource.data.offeredBy == request.auth.uid;
    }
  }
}

    // Collectibles: user owns their own, not readable by others
    match /collectibles/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }
